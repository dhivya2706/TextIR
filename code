14. Inference Functions
def infer_sr(img, text):
    Id = degrade_sr(img)
    c = ET([text])
    w = mapper(c)
    fw = fusion(c)
    feats = encoder(Id)
    return generator(feats, w.unbind(1), fw)

def infer_color(gray, text):
    gray = gray.repeat(1,3,1,1)
    c = ET([text])
    w = mapper(c)
    fw = fusion(c)
    feats = encoder(gray)
    return generator(feats, w.unbind(1), fw)

def infer_inpaint(img, mask, text):
    Id = img * mask
    c = ET([text])
    w = mapper(c)
    fw = fusion(c)
    feats = encoder(Id)
    return generator(feats, w.unbind(1), fw)
